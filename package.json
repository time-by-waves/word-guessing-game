{
  "name": "word-guessing-game",
  "version": "1.0.0",
  "description": "A multiplayer word guessing game with real-time features",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md,yml,yaml}\"",
    "prepare-dev": "npm run db:migrate && npm run db:seed",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "mcp:start": "node scripts/mcp-server.js",
    "build": "npm run lint && npm test",
    "prepare": "husky install",
    "pre-commit": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "connect-redis": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "random-words": "^2.0.1",
    "redis": "^4.6.10",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@playwright/test": "^1.40.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "playwright": "^1.40.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "socket.io-client": "^4.8.1"
  },
  "keywords": [
    "game",
    "word",
    "guessing",
    "multiplayer",
    "express",
    "socket.io"
  ],
  "author": "",
  "license": "Unlicense",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}